{
  "cli": {
    "version": ">= 16.20.4",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "GRADLE_OPTS": "-Dorg.gradle.internal.http.retry.max-retries=5 -Dorg.gradle.internal.http.retry.initial-delay-ms=2000"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "GRADLE_OPTS": "-Dorg.gradle.internal.http.retry.max-retries=5 -Dorg.gradle.internal.http.retry.initial-delay-ms=2000"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "GRADLE_OPTS": "-Dorg.gradle.internal.http.retry.max-retries=5 -Dorg.gradle.internal.http.retry.initial-delay-ms=2000"
      }
    }
  },
  "submit": {
    "production": {}
  }
}